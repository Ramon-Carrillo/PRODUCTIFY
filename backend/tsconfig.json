{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "module": "node16", // or "nodenext"
    "moduleResolution": "node16", // or "nodenext"
    "target": "es2022",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
